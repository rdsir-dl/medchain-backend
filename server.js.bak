app.get("/api/inventory/:store/:drugId", async (req, res) => {
    try {
        const { store, drugId } = req.params;
        const qty = await tokenContract.inventory(store, parseInt(drugId));
        res.json({ quantity: Number(qty) });
    } catch (e) {
        console.error("GET /api/inventory error:", e.reason || e.message);
        res.status(500).json({ error: e.reason || e.message });
    }
});

app.get("/api/audit/:store_address", async (req, res) => {
    try {
        const storeAddress = req.params.store_address;
        
        const supplyFilter = tokenContract.filters.SupplyRecorded(null, storeAddress);
        const supplyLogs = await tokenContract.queryFilter(supplyFilter, 0, "latest");
        let totalSupplied = 0;
        supplyLogs.forEach(log => { totalSupplied += Number(log.args[3]); });

        const saleFilter = tokenContract.filters.SaleRecorded(null, storeAddress);
        const saleLogs = await tokenContract.queryFilter(saleFilter, 0, "latest");
        let totalSold = 0;
        saleLogs.forEach(log => { totalSold += Number(log.args[3]); }); // quantity is args[3]

        const inv1 = await tokenContract.inventory(storeAddress, 1);
        const inv2 = await tokenContract.inventory(storeAddress, 2);
        const currentInventory = Number(inv1) + Number(inv2);

        res.json({ 
            store: storeAddress,
            totalSupplied,
            totalSold,
            currentInventory,
            mismatch: totalSupplied - totalSold - currentInventory
        });
    } catch (e) {
        console.error("GET /api/audit error:", e.reason || e.message);
        res.status(500).json({ error: e.reason || e.message });
    }
});

const PORT = process.env.PORT || 5000;
app.listen(PORT, () => {
    console.log(`PrescChain Ledger API ready on Port ${PORT}`);
});
